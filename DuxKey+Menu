-- CONFIG
local SERVICE_ID = "duxscript" -- 👈 TU SERVICE ID

--// ================== KEY SYSTEM ================== \\--

local BaseURL = "https://new.pandadevelopment.net/api/v1"

local function getHardwareId()
    local success, hwid = pcall(gethwid)
    if success and hwid then
        return hwid
    end

    local RbxAnalyticsService = game:GetService("RbxAnalyticsService")
    return tostring(RbxAnalyticsService:GetClientId()):gsub("-", "")
end

local function requestFunc(data)
    if syn and syn.request then
        return syn.request(data)
    elseif http and http.request then
        return http.request(data)
    elseif request then
        return request(data)
    else
        error("Executor no soporta requests")
    end
end

local function Validate(key)
    local HttpService = game:GetService("HttpService")

    local response = requestFunc({
        Url = BaseURL .. "/keys/validate",
        Method = "POST",
        Headers = {
            ["Content-Type"] = "application/json"
        },
        Body = HttpService:JSONEncode({
            ServiceID = SERVICE_ID,
            HWID = getHardwareId(),
            Key = key
        })
    })

    if not response or not response.Body then
        return {success = false, message = "No response"}
    end

    local data = HttpService:JSONDecode(response.Body)

    return {
        success = data.Authenticated_Status == "Success",
        message = data.Note or "Error",
        isPremium = data.Key_Premium or false,
        expireDate = data.Expire_Date
    }
end

local function GetKeyURL()
    return "https://new.pandadevelopment.net/getkey/" .. SERVICE_ID .. "?hwid=" .. getHardwareId()
end

